.dropbox {
  background: #F8F8F8;
  border: 5px dashed #DDD;
  width: 80%;
  height: 80px;
  text-align: center;
  padding-top: 15px;
  margin: 10px auto 10px auto;
}
.dragover {
  border: 5px dashed blue;
}
.photosrc {
  overflow: hidden;
  width: 100%;
  height: 300px;
  border: 1px dashed grey;
  background-color: lightgray;
}

.photoresult {
  position: relative;
  width: 100%;
  text-align: center;
  img {
    margin-left: auto;
    margin-right: auto;
  }

